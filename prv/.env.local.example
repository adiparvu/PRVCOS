# PRV — Local Development Environment
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy to .env.local:   cp .env.local.example .env.local
# 2. Start docker stack:   docker compose up -d
# 3. Run migrations:       pnpm --filter @prv/db db:migrate:run
# 4. (Optional) Full Supabase emulation: supabase start
#    Then replace the Supabase vars below with output from: supabase status
# ─────────────────────────────────────────────────────────────────────────────

NODE_ENV=development

# ─── Database (docker-compose postgres service) ───────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/prv_dev
DATABASE_DIRECT_URL=postgresql://postgres:password@localhost:5432/prv_dev

# ─── Supabase local (run `supabase start` then `supabase status` for these) ───
# If NOT using Supabase local, point at your Supabase cloud project instead.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRFA0NiK7CcryFHQ9yCZAEBFRNHlXFzNelqOELlvH8o
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hj04zWl196z2-SBc0
SUPABASE_JWT_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Redis (docker-compose redis service) ─────────────────────────────────────
# @prv/cache uses the Upstash REST API. For local dev without Upstash,
# set these to any non-empty stubs — features that require Redis will
# gracefully degrade (caching is bypassed, rate limiting is skipped).
UPSTASH_REDIS_REST_URL=http://localhost:6379
UPSTASH_REDIS_REST_TOKEN=local-dev-no-auth

# ─── Background jobs (Inngest) ────────────────────────────────────────────────
# Inngest Dev Server: npx inngest-cli@latest dev
# Get keys from: https://app.inngest.com/env/development/manage/keys
INNGEST_SIGNING_KEY=signkey-test-local
INNGEST_EVENT_KEY=local-dev-event-key

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Use a test key — emails sent in development go to Resend's logs, not inboxes.
RESEND_API_KEY=re_local_stub_key

# ─── Search (Typesense) ───────────────────────────────────────────────────────
# Start local Typesense: docker run -p 8108:8108 typesense/typesense:27.0
TYPESENSE_ADMIN_API_KEY=local-typesense-admin-key
TYPESENSE_SEARCH_API_KEY=local-typesense-search-key
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http

# ─── AI (Anthropic) ───────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ─── Monitoring (Sentry) ──────────────────────────────────────────────────────
# Leave blank in local dev to disable Sentry error reporting.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=prv
