{
  "name": "@prv/cache",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./rate-limit": "./src/rate-limit.ts",
    "./query": "./src/query.ts",
    "./pubsub": "./src/pubsub.ts",
    "./typesense": "./src/typesense.ts"
  },
  "scripts": {
