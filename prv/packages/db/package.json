{
  "name": "@prv/db",
  "version": "0.0.1",
  "private": true,
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts",
    "./storage": "./src/storage.ts",
    "./migrate": "./src/migrate.ts",
    "./rls": "./src/rls.ts",
    "./queries/kpis": "./src/queries/kpis.ts",
    "./queries/group-kpis": "./src/queries/group-kpis.ts"
  },
  "scripts": {
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:migrate:run": "tsx src/migrate.ts",
    "db:rollback": "tsx src/rollback.ts",
    "db:seed": "tsx src/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.48.1",
    "drizzle-orm": "^0.38.4",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@prv/tsconfig": "workspace:*",
    "@prv/cache": "workspace:*",
    "drizzle-kit": "^0.30.4",
    "typescript": "^5.7.3",
    "vitest": "*"
  }
}
