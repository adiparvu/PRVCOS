# PRV — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local or any file containing real secrets

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Get from: Project Settings → Database → Connection string (Transaction mode = PgBouncer)
DATABASE_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:6543/postgres

# Get from: Project Settings → Database → Connection string (Session mode = direct)
DATABASE_DIRECT_URL=postgresql://postgres.your-project:password@aws-0-region.pooler.supabase.com:5432/postgres

# Get from: Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Get from: Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-jwt-secret-min-32-chars

# ─── Inngest ──────────────────────────────────────────────────────────────────
# Get from: https://inngest.com/dashboard → App → Event Keys
INNGEST_SIGNING_KEY=signkey-prod-xxxxxxxxxxxx
INNGEST_EVENT_KEY=your-inngest-event-key

# ─── Redis (Upstash) ──────────────────────────────────────────────────────────
# Get from: https://console.upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─── Search (Typesense) ───────────────────────────────────────────────────────
# Get from: https://cloud.typesense.org → Cluster → API Keys
TYPESENSE_ADMIN_API_KEY=your-typesense-admin-key
TYPESENSE_HOST=your-cluster.a1.typesense.net
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https

# ─── AI (Anthropic) ───────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Monitoring (Sentry) ──────────────────────────────────────────────────────
# Get from: https://sentry.io → Settings → Projects → Client Keys (DSN)
SENTRY_DSN=https://your-key@sentry.io/your-project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
SENTRY_ORG=your-sentry-org-slug
SENTRY_PROJECT=prv

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Mobile (Expo) ────────────────────────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_API_URL=http://localhost:3000
