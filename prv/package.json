{
  "name": "prv",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css}\" --ignore-path .gitignore",
    "db:generate": "turbo run db:generate --filter=@prv/db",
    "db:migrate": "turbo run db:migrate --filter=@prv/db",
    "prepare": "cd .. && husky prv/.husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.4",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "19",
        "next": "16"
      },
      "ignoreMissing": [
        "expo-constants"
      ]
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,css}": [
      "prettier --write"
    ]
  }
}
